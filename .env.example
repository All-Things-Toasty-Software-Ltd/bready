# bready environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: BOT_DATA_PATH, BOT_BRIDGE_DATA_PATH, and BOT_BRIDGE_DB_DATA_PATH are
# pre-configured in the Dockerfile to /data/* and do not need to be set here
# when using the provided docker-compose.yml (the /data volume is mounted to
# ./data/bready on the host so files are directly accessible to the admin).

# Required

# Discord bot token (from the Discord Developer Portal).
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Odoo integration
# These values configure the default (fallback) Odoo instance.
# Individual users can also link their own accounts via /link.

ODOO_URL=https://yourcompany.odoo.com
ODOO_DB=your_database
ODOO_USER=you@example.com
ODOO_API_KEY=your_api_key

# Role-based access control (optional)
# Discord role snowflake IDs that gate bot access.
# Leave blank to disable the role gate (anyone in the server can use the bot).
#   Admin role  – bridge management, linking other users, all commands.
#   Member role – data commands + linking own account.
DISCORD_ADMIN_ROLE_ID=
DISCORD_MEMBER_ROLE_ID=